{
  "manifest_version": 3,
  "name": "OpenCut Cursor Tracker",
  "version": "0.1.0",
  "description": "Track cursor motion and export OpenCut-compatible tracking JSON.",
  "permissions": ["activeTab", "downloads", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "OpenCut Cursor Tracker",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
